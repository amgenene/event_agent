# EventFinder AI - Environment Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ============================================
# Required API Keys
# ============================================

# Tavily AI - Web search and event discovery (primary)
# Get at: https://tavily.com
TAVILY_API_KEY=

# OpenAI - LLM for intent parsing and event verification
# Get at: https://platform.openai.com
OPENAI_API_KEY=

# Nylas - Unified calendar API (Google, Outlook, iCloud)
# Get at: https://nylas.com
NYLAS_API_KEY=
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_GRANT_ID=

# OpenRouteService - Travel time calculations
# Get at: https://openrouteservice.org
OPENROUTE_SERVICE_API_KEY=
OPENROUTE_SERVICE_BASE_URL=https://api.openrouteservice.org

# ============================================
# Optional / Fallback
# ============================================

# Brave Search - Fallback search provider
# Get at: https://brave.com/search/api/
BRAVE_API_KEY=
BRAVE_API_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_API_TIMEOUT_SECONDS=15

# Deepgram - Alternative STT provider
# Get at: https://deepgram.com
DEEPGRAM_API_KEY=

# ============================================
# Application Settings
# ============================================

# Primary search provider: tavily or brave
DISCOVERY_PROVIDER=tavily

# Default search language
SEARCH_LANG=en

# Default search radius in miles
DEFAULT_RADIUS_MILES=5

# Default max transit time in minutes
DEFAULT_MAX_TRANSIT_MINUTES=30

# Default time window in days
DEFAULT_TIME_WINDOW_DAYS=7

# ============================================
# Observability
# ============================================

# Sentry - Error tracking (frontend + backend)
# Get at: https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Frontend Sentry DSN (public, safe to expose)
# Get at: https://sentry.io → Settings → Projects → [your-project] → Client Keys
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
